<div id="project-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="modal-content">
    <button class="modal-close" id="modal-close-btn" aria-label="Close modal">&times;</button>

    <div class="modal-label">Project Details</div>
    <h2 class="modal-title" id="modal-title"></h2>

    <div class="modal-description">
      <p id="modal-description"></p>
    </div>

    <ul class="modal-bullets" id="modal-bullets"></ul>

    <div class="modal-tech-stack" id="modal-tech-stack"></div>

    <div class="modal-footer">
      <a
        id="modal-cta"
        class="modal-cta"
        href="#"
        target="_blank"
        rel="noopener"
      >
        View Project →
      </a>
    </div>
  </div>
</div>
