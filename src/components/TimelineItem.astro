---
import type { Role } from '../data/experience';

export interface Props {
  role: Role;
}

const { role } = Astro.props;
---

<div class:list={['timeline-item', { current: role.current }]}>
  <span class="tl-date tl-date--end">{role.endDate}</span>

  <div class="timeline-header">
    <img
      src={role.logo}
      alt={`${role.company} logo`}
      class="company-logo"
      width="28"
      height="28"
      loading="lazy"
    />
    <span class="timeline-title">{role.title}</span>
    {!role.current && (
      <span class="timeline-duration">{role.duration}</span>
    )}
    {role.current && (
      <span class="current-badge">Current</span>
    )}
  </div>

  <div class="timeline-meta">
    <span class="timeline-company">{role.company}</span>
    <span class="timeline-meta-dates">&nbsp;·&nbsp; {role.startDate} – {role.endDate}</span>
  </div>

  <p class="timeline-summary">{role.summary}</p>

  <div class="job-details">
    <ul>
      {role.bullets.map((bullet) => (
        <li>{bullet}</li>
      ))}
    </ul>
  </div>

  <button class="toggle-details" aria-expanded="false">
    + Show more
  </button>

  <span class="tl-date tl-date--start">{role.startDate}</span>
</div>
