---
---

<section class="hero">
  <div class="hero-inner">
    <!-- Text content -->
    <div class="hero-content">
      <h1 class="hero-name">
        <span id="typed-text"></span><span id="typed-cursor" class="cursor"></span>
      </h1>

      <p class="hero-subtitle hero-subtitle">
        Software Engineer &nbsp;·&nbsp; Systems Thinker &nbsp;·&nbsp; Curiosity-driven
      </p>

      <div class="hero-cta">
        <a
          href="/documents/Maxwell Lubarsky Resume.pdf"
          target="_blank"
          rel="noopener"
          class="btn-primary"
        >
          View Resume
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
        <a href="#contact" class="btn-secondary">
          Get in touch
        </a>
      </div>

      <!-- Quick stats -->
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">M.S. CS</span>
          <span class="stat-label">In Progress</span>
        </div>
        <div class="stat">
          <span class="stat-value">USFCA</span>
          <span class="stat-label">University</span>
        </div>
        <div class="stat">
          <span class="stat-value">2025</span>
          <span class="stat-label">B.S. Grad</span>
        </div>
        <div class="stat">
          <span class="stat-value" style="color: var(--color-green)">Open</span>
          <span class="stat-label">to Roles</span>
        </div>
      </div>
    </div>

    <!-- Headshot -->
    <div class="hero-image">
      <div class="headshot-wrapper">
        <img
          src="/images/headshot.png"
          alt="Maxwell Lubarsky"
          width="220"
          height="220"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
